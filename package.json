{
  "name": "ocd",
  "version": "5.0.0",
  "type": "module",
  "description": "OCD (Omni Coder Dashboard) — An AI memory engine that learns from your coding sessions, recommends tools, and injects proven solutions via MCP.",
  "author": {
    "name": "Dor Lipetz",
    "url": "https://github.com/Riko5652"
  },
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/Riko5652/OCD.git"
  },
  "homepage": "https://github.com/Riko5652/OCD#readme",
  "bugs": {
    "url": "https://github.com/Riko5652/OCD/issues"
  },
  "keywords": [
    "ai",
    "productivity",
    "dashboard",
    "claude",
    "claude-code",
    "cursor",
    "copilot",
    "windsurf",
    "aider",
    "gemini",
    "mcp",
    "mcp-server",
    "developer-tools",
    "session-analytics",
    "semantic-memory",
    "vector-search",
    "prompt-engineering",
    "token-optimization",
    "local-first"
  ],
  "bin": {
    "ai-dashboard": "./bin/ai-dashboard.js",
    "ocd": "./bin/ai-dashboard.js"
  },
  "files": [
    "apps/server/dist/",
    "apps/server/package.json",
    "apps/client/dist/",
    "apps/client/package.json",
    "bin/",
    "pnpm-workspace.yaml",
    ".env.example",
    "Dockerfile",
    "docker-compose.yml",
    "README.md",
    "PRIVACY.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  },
  "scripts": {
    "dev": "pnpm --filter ./apps/* run dev",
    "build": "pnpm --filter ./apps/* run build",
    "start": "pnpm --filter ./apps/server run start",
    "mcp": "pnpm --filter ./apps/server run mcp",
    "doctor": "node bin/doctor.mjs",
    "feedback": "node bin/feedback.mjs",
    "test": "pnpm --filter @ocd/server run test",
    "prepare": "pnpm run build"
  }
}
