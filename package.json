{
  "name": "omni-coder-dashboard",
  "version": "5.5.0",
  "type": "module",
  "description": "OCD (Omni Coder Dashboard) — An AI memory engine with real semantic embeddings, 21 MCP tools, cross-tool routing, trace auditing, and proactive IDE interception. 100% local, zero API keys required.",
  "author": {
    "name": "Dor Lipetz",
    "url": "https://github.com/Riko5652"
  },
  "license": "AGPL-3.0-or-later",
  "repository": {
    "type": "git",
    "url": "https://github.com/Riko5652/OCD.git"
  },
  "homepage": "https://github.com/Riko5652/OCD#readme",
  "bugs": {
    "url": "https://github.com/Riko5652/OCD/issues"
  },
  "keywords": [
    "ai",
    "productivity",
    "dashboard",
    "claude",
    "claude-code",
    "cursor",
    "copilot",
    "windsurf",
    "aider",
    "gemini",
    "mcp",
    "mcp-server",
    "developer-tools",
    "session-analytics",
    "semantic-memory",
    "vector-search",
    "onnx",
    "embeddings",
    "prompt-engineering",
    "token-optimization",
    "local-first",
    "ide-interception"
  ],
  "bin": {
    "ai-dashboard": "./bin/ai-dashboard.js",
    "ocd": "./bin/ai-dashboard.js"
  },
  "files": [
    "apps/server/dist/",
    "apps/server/package.json",
    "apps/client/dist/",
    "apps/client/package.json",
    "bin/",
    "pnpm-workspace.yaml",
    ".env.example",
    "Dockerfile",
    "docker-compose.yml",
    "README.md",
    "PRIVACY.md"
  ],
  "engines": {
    "node": ">=18.18.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ],
    "overrides": {
      "flatted": ">=3.4.2",
      "esbuild": ">=0.25.0",
      "path-to-regexp": ">=8.4.0",
      "brace-expansion": ">=5.0.5",
      "picomatch": ">=4.0.4"
    }
  },
  "scripts": {
    "dev": "pnpm --filter './apps/*' run dev",
    "build": "pnpm --filter './apps/*' run build",
    "start": "pnpm --filter ./apps/server run start",
    "mcp": "pnpm --filter ./apps/server run mcp",
    "doctor": "node bin/doctor.mjs",
    "feedback": "node bin/feedback.mjs",
    "install-hook": "node bin/install-hook.js",
    "lint": "pnpm -r run lint",
    "test": "pnpm --filter @ocd/server run test",
    "prepublishOnly": "pnpm run build && npm pack --dry-run",
    "prepare": "pnpm run build"
  }
}
