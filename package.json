{
  "name": "ai-productivity-dashboard",
  "version": "3.0.0",
  "type": "module",
  "description": "Universal Brain for AI-assisted coding — tracks Claude Code, Cursor, Aider, Windsurf, Copilot & Gemini, benchmarks tools+models, routes tasks to your best combo, and exposes a live MCP server for any AI agent",
  "author": {
    "name": "Dor Lipetz",
    "url": "https://github.com/Riko5652"
  },
  "license": "AGPL-3.0-or-later",
  "homepage": "https://github.com/Riko5652/ai-productivity-dashboard",
  "repository": {
    "type": "git",
    "url": "https://github.com/Riko5652/ai-productivity-dashboard.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "ai-dashboard": "./bin/ai-dashboard.js",
    "ai-dashboard-mcp": "./src/mcp-handoff.js"
  },
  "files": [
    "bin/",
    "scripts/",
    "src/",
    "public/",
    "Dockerfile",
    "docker-compose.yml",
    "seed-mock.mjs",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "prestart": "node scripts/ensure-env.js",
    "predev": "node scripts/ensure-env.js",
    "start": "node --env-file=.env src/server.js",
    "dev": "node --env-file=.env --watch src/server.js",
    "mcp": "node src/mcp-handoff.js",
    "docker:build": "docker build -t ai-dashboard .",
    "docker:up": "docker compose up",
    "docker:down": "docker compose down",
    "audit": "npm audit --production"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "better-sqlite3": "^11.7.0",
    "chokidar": "^4.0.0",
    "express": "^4.21.0"
  },
  "keywords": [
    "ai",
    "productivity",
    "dashboard",
    "claude-code",
    "cursor",
    "aider",
    "windsurf",
    "copilot",
    "gemini",
    "analytics",
    "developer-tools",
    "prompt-optimization",
    "llm",
    "mcp",
    "model-context-protocol",
    "sqlite",
    "local-first",
    "docker",
    "vibe-coding",
    "agentic-coding"
  ]
}
