# AI Productivity Dashboard v3 — Configuration
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and customize as needed.
# Everything is auto-detected by default — you can start with zero config.
#
# Docker users: pass env vars via docker-compose.yml or -e flags.
#   docker run -e PORT=3030 -e ANTHROPIC_API_KEY=... ai-dashboard
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ───────────────────────────────────────────────────────────────────
PORT=3030
DB_PATH=./data/analytics.db
# Docker: DB_PATH=/app/data/analytics.db

# How many days of history to show by default in charts and stats.
# 0 = all-time (default). Set to 365 for last year, 90 for last 3 months, etc.
# Individual API endpoints accept ?days=N to override per-request.
# HISTORY_DAYS=0

# BIND defaults to 127.0.0.1 (localhost only — your data stays private).
# Set to 0.0.0.0 only if you need LAN access or are running in Docker.
# BIND=0.0.0.0

# ── Claude Code ──────────────────────────────────────────────────────────────
# Auto-discovers all projects under ~/.claude/projects/
# Override to scan only one project:
# CLAUDE_PROJECT_DIR=~/.claude/projects/my-project

# ── Cursor ───────────────────────────────────────────────────────────────────
# Auto-detected per platform (Windows/macOS/Linux)
# Override for non-standard locations:
# CURSOR_STATE_DB=/path/to/state.vscdb
# CURSOR_TRACKING_DB=/path/to/ai-code-tracking.db

# Drop state.vscdb files from other machines here to merge their stats:
# CURSOR_IMPORT_DIR=./cursor-imports

# Cursor team usage CSV (export from cursor.com admin dashboard):
# CURSOR_CSV_DIR=./

# ── Gemini / Antigravity ──────────────────────────────────────────────────────
# ANTIGRAVITY_DIR=~/.gemini/antigravity

# ── Aider ────────────────────────────────────────────────────────────────────
# Auto-discovers .aider.chat.history.md files in the current working directory
# AIDER_LOGS_DIR=~/.aider/logs

# ── Windsurf (Codeium) ────────────────────────────────────────────────────────
# Auto-detected per platform
# WINDSURF_DB=/path/to/codeium/db/ai_usage.db

# ── GitHub Copilot ────────────────────────────────────────────────────────────
# Auto-detected per platform from VS Code's globalStorage directory.
# Override if you use VS Code Insiders or a non-standard install:
# COPILOT_STORAGE_DIR=/path/to/Code/User/globalStorage

# ── Continue.dev ──────────────────────────────────────────────────────────────
# CONTINUE_SESSIONS_DIR=~/.continue/sessions

# ── LLM Provider — for Deep Analyze, Daily Automation Pick & Project Suggestions ─
# Priority order: Ollama (local, free) → Azure OpenAI → OpenAI → Anthropic
# You don't need any LLM to use the dashboard — it's optional for AI features.

# Local Ollama (completely free, runs on your machine)
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_MODEL=gemma2:2b
# Docker users pointing to host Ollama:
# OLLAMA_HOST=http://host.docker.internal:11434

# Azure OpenAI
# AZURE_OPENAI_API_KEY=your-key-here
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT_CHAT=gpt-5.2-chat

# Vanilla OpenAI
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

# Anthropic Claude
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── MCP Server ────────────────────────────────────────────────────────────────
# Register with Claude Code by adding to .mcp.json in your project root:
# {
#   "mcpServers": {
#     "ai-brain": {
#       "command": "npx",
#       "args": ["ai-productivity-dashboard", "--mcp"]
#     }
#   }
# }
# Or if installed globally: { "command": "ai-dashboard-mcp", "args": [] }
