# AI Productivity Dashboard — Configuration
# Copy this file to .env and customize as needed.
# All paths are auto-detected by default — only override if needed.

# Server
PORT=3030
DB_PATH=./data/analytics.db

# Claude Code — auto-discovers all projects under ~/.claude/projects/
# Override to scan a specific project directory only:
# CLAUDE_PROJECT_DIR=~/.claude/projects/my-project

# Cursor — auto-detected per platform (Windows/macOS/Linux)
# Override for non-standard locations:
# CURSOR_STATE_DB=/path/to/state.vscdb
# CURSOR_TRACKING_DB=/path/to/ai-code-tracking.db

# Cursor imports — drop state.vscdb from other machines here
# CURSOR_IMPORT_DIR=./cursor-imports

# Cursor team usage CSV — export from cursor.com admin dashboard
# Place team-usage-events-*.csv files in this directory:
# CURSOR_CSV_DIR=./

# Gemini / Antigravity
# ANTIGRAVITY_DIR=~/.gemini/antigravity
